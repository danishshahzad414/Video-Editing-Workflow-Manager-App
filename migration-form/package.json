{
  "name": "migration-form",
  "version": "1.0.0",
  "description": "Migration Form Remotion Composition",
  "scripts": {
    "start": "remotion studio --port=3004",
    "render:webm": "remotion render MigrationForm out/migration-form.webm --codec=vp8 --pixel-format=yuva420p",
    "render:prores": "remotion render MigrationForm out/migration-form.mov --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le",
    "render": "npm run render:webm"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "typescript": "5.4.5"
  },
  "remotion": {
    "entryPoint": "./src/index.ts"
  }
}
